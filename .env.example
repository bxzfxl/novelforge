# ── Remote Agent ───────────────────────────────────────────
AGENT_PORT=9100
# 项目根目录（Docker 容器内挂载路径为 /project）
PROJECT_ROOT=/home/ubuntu/novelforge/novelforge
# CLI 路径（确保已安装并认证）
CLAUDE_PATH=claude
GEMINI_PATH=gemini
# 最大并发进程数
MAX_CLAUDE=2
MAX_GEMINI=2

# ── Web Console ───────────────────────────────────────────
# Remote Agent 地址（部署时改为服务器公网 IP 或域名）
NEXT_PUBLIC_AGENT_URL=http://localhost:9100
# 宿主机 IP（Docker 内部服务间通信用）
HOST_IP=localhost
