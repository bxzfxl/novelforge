{
  "name": "@novelforge/desktop",
  "version": "0.1.0",
  "private": true,
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "concurrently \"vite\" \"tsx scripts/dev-main.ts\"",
    "dev:debug": "concurrently \"vite\" \"tsx scripts/dev-main.ts --inspect\"",
    "build": "vite build && tsc -p tsconfig.main.json",
    "build:desktop": "pnpm build && electron-builder",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.main.json",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@novelforge/shared": "workspace:*",
    "@novelforge/prompts": "workspace:*",
    "@anthropic-ai/sdk": "^0.50.0",
    "@google/generative-ai": "^0.24.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "better-sqlite3": "^11.0.0",
    "openai": "^5.0.0",
    "uuid": "^11.0.0",
    "yaml": "^2.7.0",
    "zod": "^3.24.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.50.0",
    "@tailwindcss/vite": "^4.0.0",
    "@types/better-sqlite3": "^7.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.4.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "concurrently": "^9.0.0",
    "electron": "^34.0.0",
    "electron-builder": "^26.0.0",
    "lucide-react": "^0.460.0",
    "tailwind-merge": "^2.5.0",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.19.0",
    "vite": "^6.0.0"
  }
}
